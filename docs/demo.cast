[11.808836, "o", "Detect and sweep dust attack UTXOs from your Bitcoin wallet\r\n\r\n\u001b[1m\u001b[4mUsage:\u001b[0m \u001b[1mdust-cleaner\u001b[0m [OPTIONS] \u001b[1m--rpc-user\u001b[0m <RPC_USER> \u001b[1m--rpc-pass\u001b[0m <RPC_PASS> <COMMAND>\r\n\r\n\u001b[1m\u001b[4mCommands:\u001b[0m\r\n  \u001b[1mscan\u001b[0m   Scan wallet for dust UTXOs\r\n  \u001b[1msweep\u001b[0m  Create a PSBT sweeping all dust UTXOs\r\n  \u001b[1mhelp\u001b[0m   Print this message or the help of the given subcommand(s)\r\n\r\n\u001b[1m\u001b[4mOptions:\u001b[0m\r\n      \u001b[1m--rpc-url\u001b[0m <RPC_URL>      Bitcoin Core RPC URL [env: DUST_RPC_URL=] [default: http://127.0.0.1:18443]\r\n      \u001b[1m--rpc-user\u001b[0m <RPC_USER>    Bitcoin Core RPC username [env: DUST_RPC_USER=user]\r\n      \u001b[1m--rpc-pass\u001b[0m <RPC_PASS>    Bitcoin Core RPC password [env: DUST_RPC_PASS=pass]\r\n      \u001b[1m--threshold\u001b[0m <THRESHOLD>  Dust threshold in sats. If omitted, uses per-script-type thresholds [env: DUST_THRESHOLD=]\r\n  \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m                   Print help\r\n"]
